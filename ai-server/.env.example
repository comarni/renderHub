# ========================================
# RenderHub AI-Server Configuration
# ========================================

# Server
PORT=8787
DEBUG=false
CORS_ORIGIN=*

# ========================================
# Mode Selection
# ========================================
# Options: 'mock' (demo models), 'upstream' (delegate to real service)
AI3D_MODE=upstream

# ========================================
# Mode: upstream (Real 3D Generation)
# ========================================

# Option 1: TripoSR Local (GPU-accelerated)
# Setup: cd tripo-sr-wrapper && python app.py
# GPU: CUDA RTX 3090 → 15-45s per image
# CPU: Intel i7 → 5-15 min per image (testing only)
# Port: 9000 (default)
AI3D_UPSTREAM_CREATE_URL=http://127.0.0.1:9000/api/v1/image-to-3d
AI3D_UPSTREAM_STATUS_URL=http://127.0.0.1:9000/api/v1/jobs/{jobId}
AI3D_UPSTREAM_RESULT_FIELD=glbUrl

# Option 2: Replicate API (Cloud, requires account)
# Sign up: https://replicate.com
# Install: pip install replicate
# Model: stability-ai/stablelm-3b-4k-instruct or similar
# Cost: ~$0.0005 per image (estimate)
# AI3D_UPSTREAM_CREATE_URL=https://api.replicate.com/v1/predictions
# AI3D_API_KEY=<your-replicate-token>
# AI3D_UPSTREAM_RESULT_FIELD=output[0].images[0].url

# Option 3: Hugging Face Inference API
# Sign up: https://huggingface.co
# Model: stabilityai/stable-diffusion-3-medium
# Cost: ~$0.002 per image (estimate)
# AI3D_UPSTREAM_CREATE_URL=https://api-inference.huggingface.co/models/{model_id}
# AI3D_API_KEY=<your-hf-token>

# API Key (if using cloud service)
AI3D_API_KEY=

# Job polling & timeout
AI3D_JOB_POLL_INTERVAL_MS=2500
AI3D_JOB_MAX_POLLS=120
AI3D_JOB_TIMEOUT_S=300
